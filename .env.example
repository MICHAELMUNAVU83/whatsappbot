# Copy this file to .env for local development.
# Environment variables exported by your shell still take precedence.

OPENAI_API_KEY=sk-proj-your-openai-key
OPENAI_MODEL=gpt-5.5

# WhatsApp Cloud API.
# Per-workspace credentials (Phone Number ID, WABA ID, Access Token) are set in
# the dashboard at /workspaces/:id/meta, not here. Only the global Graph API
# version is read from the environment (optional; defaults to v21.0).
WHATSAPP_GRAPH_API_VERSION=v21.0

# Required for the webhook callback URL shown on the Meta Connection screen.
# In production this must be your public HTTPS hostname.
PHX_HOST=localhost
